# Server
PORT=8080
ENV=                          # Set to "local" to allow http://localhost:8000 as an allowed origin

# CORS — comma-separated list of allowed origins (defaults to https://reader.inkfeed.xyz,http://reader.inkfeed.xyz)
ALLOWED_ORIGINS=

# Email — required for send-to-Kindle functionality
EMAIL_PROVIDER=               # brevo | mailersend | resend
EMAIL_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=

# Feed proxy — Cloudflare Worker URL used to fetch feeds server-side
FEED_PROXY_URL=

# Rate limiting
RATE_LIMIT_MAX=40
RATE_LIMIT_WINDOW_SECONDS=60
SIGNIN_RATE_LIMIT_MAX=10
SIGNUP_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_HOURS=1
AUTH_RATE_LIMIT_BLOCK_HOURS=2

# Image processing
IMAGE_QUALITY=50              # JPEG compression quality (1–100)
IMAGE_COMPRESSION=true

# Caching
ARTICLE_CACHE_TTL_MINUTES=60
COMMENTS_CACHE_TTL_MINUTES=30

# Feed scraping
FEED_SCRAPE_INTERVAL_HOURS=1
FEED_ITEMS_MAX_AGE_HOURS=336  # 14 days
FEED_ITEMS_PRUNE_INTERVAL_HOURS=1
MAX_ARCHIVED_FEEDS=50
CONTENT_ARCHIVER_TIMEOUT_SECONDS=5
